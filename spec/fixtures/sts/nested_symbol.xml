    <sec id="sec_3">
      <title>3 Terms and definitions</title>
      <label>3</label>
      <term-sec id="sec_3.1">
        <label>3.1</label>
        <tbx:termEntry id="term_3.1">
          <tbx:langSet xml:lang="en">
            <tbx:definition>velocity measured in metres per second</tbx:definition>
            <tbx:tig id="tig_3.1-1">
              <tbx:term>v</tbx:term>
              <tbx:termType value="symbol"/>
              <tbx:normativeAuthorization value="admittedTerm"/>
            </tbx:tig>
            <tbx:tig id="tig_3.1-2">
              <tbx:term>velocity</tbx:term>
              <tbx:partOfSpeech value="noun"/>
              <tbx:normativeAuthorization value="preferredTerm"/>
            </tbx:tig>
            <tbx:subjectField>physics</tbx:subjectField>
          </tbx:langSet>
        </tbx:termEntry>
        <term-sec id="sec_3.1.1">
          <label>3.1.1</label>
          <tbx:termEntry id="term_3.1.1">
            <tbx:langSet xml:lang="en">
              <tbx:definition>the maximum velocity attainable</tbx:definition>
              <tbx:tig id="tig_3.1.1-1">
                <tbx:term>terminal velocity</tbx:term>
                <tbx:partOfSpeech value="noun"/>
                <tbx:normativeAuthorization value="preferredTerm"/>
              </tbx:tig>
              <tbx:note>A falling object reaches terminal velocity.</tbx:note>
            </tbx:langSet>
          </tbx:termEntry>
        </term-sec>
      </term-sec>
